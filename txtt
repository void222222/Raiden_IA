# ==========================================

# 👂 MÓDULO: OS OUVIDOS (Microfone Ajustado)

# ==========================================

def ouvir_microfone():

reconhecedor = sr.Recognizer()

# 🛑 O SEGREDO DA PACIÊNCIA:

# Espera 2 segundos de silêncio antes de achar que você terminou de falar.

reconhecedor.pause_threshold = 2.0

with sr.Microphone() as fonte:

print("\n🎤 Raiden está ouvindo... (Pode falar no seu tempo!)")

reconhecedor.adjust_for_ambient_noise(fonte, duration=1)

try:

# timeout=10: Ela espera até 10 seg pra você começar a falar

# phrase_time_limit=30: Você pode falar por até 30 segundos seguidos

audio = reconhecedor.listen(fonte, timeout=10, phrase_time_limit=30)

print("⏳ Entendendo o que você disse...")

texto = reconhecedor.recognize_google(audio, language="pt-BR")

# 🛑 NOVO FILTRO ANTI-ALUCINAÇÃO:

# Se você tossir ou falar só uma palavra ("ah", "é"), ela ignora.

if len(texto.split()) < 2:

print("Você resmungou algo curto demais, ignorando...")

return ""

print(f"Você: {texto}")

return texto

except sr.UnknownValueError:

return ""

except sr.WaitTimeoutError:

return ""

except Exception as e:

print(f"❌ Erro: {e}")

return ""


# ... (MANTENHA A PARTE DA BOCA E DO ALSA COMO ESTAVAM) ...


# ==========================================

# 🧠 MÓDULO: O CÉREBRO (Ollama Focado)

# ==========================================

url = "http://localhost:11434/api/generate"

personalidade = "Você é a Raiden. Uma assistente virtual muito inteligente, sarcástica e tsundere. Gosta de chamar o usuário de idiota ou preguiçoso, mas no fundo ajuda ele. Responda de forma curta (máximo 2 frases)."


print("\n⚡ ACORDANDO A RAIDEN... (Fale 'encerrar' para sair)")

falar("Estou online. Pare de enrolar e me diga o que você quer.")


