import requests

import speech_recognition as sr

import os

import time

import re

import sqlite3


os.environ['PYGAME_HIDE_SUPPORT_PROMPT'] = "hide"

from gtts import gTTS

import pygame

from ctypes import *


# ==========================================

# 🛑 FEITIÇARIA PARA ESCONDER OS ERROS DO ALSA (LINUX)

# ==========================================

ERROR_HANDLER_FUNC = CFUNCTYPE(None, c_char_p, c_int, c_char_p, c_int, c_char_p)

def py_error_handler(filename, line, function, err, fmt):

pass

c_error_handler = ERROR_HANDLER_FUNC(py_error_handler)

try:

asound = cdll.LoadLibrary('libasound.so.2')

asound.snd_lib_error_set_handler(c_error_handler)

except OSError:

pass


# ==========================================

# 📓 MÓDULO: A MEMÓRIA (SQLite)

# ==========================================

def iniciar_caderno():

conexao = sqlite3.connect("memoria_raiden.db")

cursor = conexao.cursor()

# Tabela de histórico (Conversa)

cursor.execute('''

CREATE TABLE IF NOT EXISTS historico (

id INTEGER PRIMARY KEY AUTOINCREMENT,

autor TEXT,

mensagem TEXT

)

''')

# 📅 NOVA TABELA: Agenda de Compromissos

cursor.execute('''

CREATE TABLE IF NOT EXISTS agenda (

id INTEGER PRIMARY KEY AUTOINCREMENT,

tarefa TEXT,

data TEXT

)

''')

conexao.commit()

return conexao


def anotar_no_caderno(conexao, autor, mensagem):

cursor = conexao.cursor()

cursor.execute("INSERT INTO historico (autor, mensagem) VALUES (?, ?)", (autor, mensagem))

conexao.commit()


def ler_ultimas_conversas(conexao, limite=4):

cursor = conexao.cursor()

cursor.execute("SELECT autor, mensagem FROM historico ORDER BY id DESC LIMIT ?", (limite,))

linhas = cursor.fetchall()

linhas.reverse()

contexto = ""

for linha in linhas:

contexto += f"{linha[0]} diz: {linha[1]}\n"

return contexto


def salvar_tarefa(conexao, tarefa):

cursor = conexao.cursor()

data_atual = time.strftime("%d/%m/%Y") # Pega a data de hoje

cursor.execute("INSERT INTO agenda (tarefa, data) VALUES (?, ?)", (tarefa, data_atual))

conexao.commit()

return f"Tarefa '{tarefa}' anotada no caderno, preguiçoso."


def listar_tarefas(conexao):

cursor = conexao.cursor()

cursor.execute("SELECT tarefa FROM agenda")

tarefas = cursor.fetchall()

if not tarefas:

return "Sua agenda está vazia. Pelo menos nisso você não é um desastre."

lista = "Suas tarefas são: " + ", ".join([t[0] for t in tarefas])

return lista


# ==========================================

# 👄 MÓDULO: A BOCA

# ==========================================

pygame.mixer.init()


def limpar_texto_para_voz(texto):

texto_limpo = texto.replace('"', '').replace('”', '').replace('“', '').replace("'", "")

texto_limpo = texto_limpo.replace('*', '')

texto_limpo = re.sub(r'\(.*?\)', '', texto_limpo)

return texto_limpo


def falar(texto):

texto_processado = limpar_texto_para_voz(texto)

print("🗣️ Raiden está falando...")

tts = gTTS(text=texto_processado, lang='pt', slow=False)

arquivo_audio = "voz.mp3"

tts.save(arquivo_audio)

pygame.mixer.music.load(arquivo_audio)

pygame.mixer.music.play()

while pygame.mixer.music.get_busy():

time.sleep(0.1)

os.remove(arquivo_audio)


# ==========================================

# 👂 MÓDULO: OS OUVIDOS (Agora com Modo Standby)

# ==========================================

# Adicionei a variável 'silencioso' para ela não ficar floodando o terminal de texto

def ouvir_microfone(silencioso=False):

reconhecedor = sr.Recognizer()

# 🛑 AJUSTES DE "PACIÊNCIA" (Para não te cortar)

# Aumentamos para 2.5 segundos. Ela só para de ouvir se você ficar em silêncio ABSOLUTO por esse tempo.

reconhecedor.pause_threshold = 2.5

# Ela vai ignorar barulhos de fundo constantes (como o cooler do seu PC)

reconhecedor.dynamic_energy_threshold = True

reconhecedor.energy_threshold = 400 # Sensibilidade base (ajuste se precisar)


with sr.Microphone() as fonte:

if silencioso:

# No modo standby, ela precisa ser rápida para pegar o "Raiden"

print("\n💤 Raiden em standby...")

else:

print("\n🎤 Pode falar, não vou te cortar...")

# Ajuste de ruído super rápido (0.3s) para não perder o início da sua fala

reconhecedor.adjust_for_ambient_noise(fonte, duration=0.3)

try:

# phrase_time_limit=None permite que você fale por 1 hora se quiser

audio = reconhecedor.listen(fonte, timeout=None, phrase_time_limit=None)

if not silencioso:

print("⏳ Processando sua voz...")

texto = reconhecedor.recognize_google(audio, language="pt-BR").lower()

if texto.strip() == "":

return ""

return texto

except sr.UnknownValueError:

# Ela ouviu um som mas não entendeu palavra nenhuma

return ""

except Exception as e:

return ""# ==========================================

