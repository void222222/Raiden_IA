mensagem_usuario = ouvir_microfone()

if mensagem_usuario == "":

continue

if "encerrar" in mensagem_usuario.lower() or "sair" in mensagem_usuario.lower():

print("Raiden: Finalmente me deu paz. Já vai tarde!")

falar("Finalmente me deu paz. Já vai tarde!")

break


pacote = {

"model": "llama3",

"prompt": f"{personalidade}\nUsuário diz: {mensagem_usuario}\nRaiden responde:",

"stream": False,

# 🛑 REMÉDIO ANTI-ALUCINAÇÃO:

# A temperatura vai de 0.0 (robótico/preciso) a 1.0 (muito criativo/louco).

# 0.4 ou 0.5 deixa a resposta inteligente, focada e sem enrolação.

"options": {

"temperature": 0.4

}

}


try:

print("🧠 Raiden está pensando...")

resposta = requests.post(url, json=pacote)

dados = resposta.json()

if "error" in dados:

print(f"\n❌ Erro no Ollama: {dados['error']}")

else:

texto_resposta = dados['response']

print(f"Raiden: {texto_resposta}")

falar(texto_resposta)

print("-" * 40)


except Exception as e:

print(f"Deu ruim na conexão! Erro: {e}")

break


📖 O que mudou?


reconhecedor.pause_threshold = 2.0: Antes, ela te cortava em menos de 1 segundo. Agora, você tem 2 segundos inteiros para respirar no meio de uma frase sem que ela te interrompa.


Filtro de palavras if len(texto.split()) < 2:: Se o microfone captar um estalo, um suspiro ou uma palavra isolada, ela não vai mandar isso pro Ollama. Isso previne o Ollama de tentar responder a ruídos do seu quarto.


"temperature": 0.4 no pacote JSON: Essa é uma configuração secreta maravilhosa. Modelos como Llama3 vêm com temperatura padrão alta. Baixando para 0.4, as respostas ficam mais curtas, lógicas e coesas com a personalidade Tsundere.


