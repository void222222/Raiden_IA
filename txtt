    pacote = {
        "model": "llama3",
        "prompt": f"{personalidade}\n\nHistórico recente da conversa:\n{contexto_historico}\nRaiden responde:",
        "stream": False,
        "options": {
            "temperature": 0.5,      # Um pouco mais de criatividade para variar as palavras
            "repeat_penalty": 1.5,   # 🛑 PENALIDADE: Impede ela de repetir frases iguais
            "top_k": 40,             # Limita as opções de palavras para ser mais direta
            "top_p": 0.9             # Ajuda na diversidade do vocabulário
