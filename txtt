import requests

import speech_recognition as sr

import os

import time

import re

import sqlite3

import webbrowser


os.environ['PYGAME_HIDE_SUPPORT_PROMPT'] = "hide"

from gtts import gTTS

import pygame

from ctypes import *


# ==========================================

# 🛑 FEITIÇARIA PARA ESCONDER OS ERROS DO ALSA (LINUX)

# ==========================================

ERROR_HANDLER_FUNC = CFUNCTYPE(None, c_char_p, c_int, c_char_p, c_int, c_char_p)

def py_error_handler(filename, line, function, err, fmt): pass

c_error_handler = ERROR_HANDLER_FUNC(py_error_handler)

try:

asound = cdll.LoadLibrary('libasound.so.2')

asound.snd_lib_error_set_handler(c_error_handler)

except OSError: pass


# ==========================================

# 📓 MÓDULO: A MEMÓRIA E ESTADO (SQLite)

# ==========================================

def iniciar_caderno():

conexao = sqlite3.connect("memoria_raiden.db")

cursor = conexao.cursor()

cursor.execute('CREATE TABLE IF NOT EXISTS historico (id INTEGER PRIMARY KEY AUTOINCREMENT, autor TEXT, mensagem TEXT)')

cursor.execute('CREATE TABLE IF NOT EXISTS agenda (id INTEGER PRIMARY KEY AUTOINCREMENT, tarefa TEXT, data TEXT)')

cursor.execute('CREATE TABLE IF NOT EXISTS estado (chave TEXT PRIMARY KEY, valor INTEGER)')

cursor.execute('INSERT OR IGNORE INTO estado (chave, valor) VALUES ("irritacao", 0)')

conexao.commit()

return conexao


def ajustar_humor(conexao, pontos):

cursor = conexao.cursor()

cursor.execute("SELECT valor FROM estado WHERE chave = 'irritacao'")

atual = cursor.fetchone()[0]

novo = max(0, min(100, atual + pontos))

cursor.execute("UPDATE estado SET valor = ? WHERE chave = 'irritacao'", (novo,))

conexao.commit()

return novo


def anotar_no_caderno(conexao, autor, mensagem):

cursor = conexao.cursor()

cursor.execute("INSERT INTO historico (autor, mensagem) VALUES (?, ?)", (autor, mensagem))

conexao.commit()


def ler_ultimas_conversas(conexao, limite=4):

cursor = conexao.cursor()

cursor.execute("SELECT autor, mensagem FROM historico ORDER BY id DESC LIMIT ?", (limite,))

linhas = cursor.fetchall()

linhas.reverse()

return "".join([f"{l[0]}: {l[1]}\n" for l in linhas])


def salvar_tarefa(conexao, tarefa):

cursor = conexao.cursor()

data_atual = time.strftime("%d/%m/%Y")

cursor.execute("INSERT INTO agenda (tarefa, data) VALUES (?, ?)", (tarefa, data_atual))

conexao.commit()

return f"Tarefa '{tarefa}' anotada."


def listar_tarefas(conexao):

cursor = conexao.cursor()

cursor.execute("SELECT tarefa FROM agenda")

tarefas = cursor.fetchall()

if not tarefas: return "Sua agenda está vazia."

return "Suas tarefas são: " + ", ".join([t[0] for t in tarefas])


# ==========================================

# 👄 MÓDULO: A BOCA

# ==========================================

pygame.mixer.init()


def falar(texto):

# A Mágica de limpeza: Retira qualquer tag [COMO_ESSA] antes de falar

texto_limpo = re.sub(r'\[.*?\]', '', texto)

texto_limpo = texto_limpo.replace('"', '').replace('*', '').strip()

print("🗣️ Raiden falando...")

tts = gTTS(text=texto_limpo, lang='pt', slow=False)

tts.save("voz.mp3")

pygame.mixer.music.load("voz.mp3")

pygame.mixer.music.play()

while pygame.mixer.music.get_busy():

time.sleep(0.1)

os.remove("voz.mp3")


# ==========================================

# 👂 MÓDULO: OS OUVIDOS

# ==========================================

def ouvir_microfone(silencioso=False, tempo_limite=None):

reconhecedor = sr.Recognizer()

reconhecedor.pause_threshold = 2.5

reconhecedor.dynamic_energy_threshold = True


with sr.Microphone() as fonte:

if silencioso: print("\n💤 Standby... (Monitorando vácuo)")

else: print("\n🎤 Pode falar, não vou te cortar...")

reconhecedor.adjust_for_ambient_noise(fonte, duration=0.3)

try:

audio = reconhecedor.listen(fonte, timeout=tempo_limite, phrase_time_limit=None)

if not silencioso: print("⏳ Processando voz...")

texto = reconhecedor.recognize_google(audio, language="pt-BR").lower()

return texto if texto.strip() != "" else ""

except:

return ""


