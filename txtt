extends Node3D


# ========================================================

# 🎮 CONTROLES REMOTOS (Tudo zerado = T-Pose)

# ========================================================

@export_group("Ajuste dos Ombros")

@export var ombro_esquerdo: Vector3 = Vector3(0, 0, 0)

@export var ombro_direito: Vector3 = Vector3(0, 0, 0)


@export_group("Ajuste dos Braços")

@export var braco_esquerdo: Vector3 = Vector3(0, 0, 0)

@export var braco_direito: Vector3 = Vector3(0, 0, 0)


var _socket = WebSocketPeer.new()

@onready var _skeleton: Skeleton3D = $GeneralSkeleton

@onready var _mesh: MeshInstance3D = _find_mesh(self)


var _mouth_idx = -1

var _blink_idx = -1

var _expr_map = {"joy": -1, "angry": -1, "sorrow": -1, "fun": -1}

var _blend_targets = {}

var _blend_current = {}

var _idle_time = 0.0


var _left_shoulder_idx = -1

var _right_shoulder_idx = -1

var _left_arm_idx = -1

var _right_arm_idx = -1

var _head_idx = -1


var _target_head_rot: Quaternion = Quaternion.IDENTITY

var _current_head_rot: Quaternion = Quaternion.IDENTITY

var _head_timer: float = 0.0

var _tempo_proximo_olhar: float = 3.0


func _ready():

    get_viewport().transparent_bg = true

    if has_node("AnimationPlayer"):

        $AnimationPlayer.queue_free()


    _left_shoulder_idx = _skeleton.find_bone("LeftShoulder")

    _right_shoulder_idx = _skeleton.find_bone("RightShoulder")

    _left_arm_idx = _skeleton.find_bone("LeftUpperArm")

    _right_arm_idx = _skeleton.find_bone("RightUpperArm")

    _head_idx = _skeleton.find_bone("Head")


    _detect_blend_shapes()

    if _mesh and _mesh.mesh:

        for i in range(_mesh.mesh.get_blend_shape_count()):

            _blend_targets[i] = 0.0

            _blend_current[i] = 0.0


    _socket.connect_to_url("ws://localhost:8080")

    _piscar_loop()


func _process(delta):

    # ----- 1. CONTROLES REMOTOS EM TEMPO REAL -----

    if _left_shoulder_idx != -1:


        _skeleton.set_bone_pose_rotation(_left_shoulder_idx,

Quaternion.from_euler(Vector3(deg_to_rad(ombro_esquerdo.x),

deg_to_rad(ombro_esquerdo.y), deg_to_rad(ombro_esquerdo.z))))

    if _right_shoulder_idx != -1:


        _skeleton.set_bone_pose_rotation(_right_shoulder_idx,

Quaternion.from_euler(Vector3(deg_to_rad(ombro_direito.x),

deg_to_rad(ombro_direito.y), deg_to_rad(ombro_direito.z))))


    if _left_arm_idx != -1:


        _skeleton.set_bone_pose_rotation(_left_arm_idx,

Quaternion.from_euler(Vector3(deg_to_rad(braco_esquerdo.x),

deg_to_rad(braco_esquerdo.y), deg_to_rad(braco_esquerdo.z))))

    if _right_arm_idx != -1:


        _skeleton.set_bone_pose_rotation(_right_arm_idx,

Quaternion.from_euler(Vector3(deg_to_rad(braco_direito.x),

deg_to_rad(braco_direito.y), deg_to_rad(braco_direito.z))))


    # ----- 2. OLHAR ALEATÓRIO -----

    if _head_idx != -1:

        _head_timer += delta

        if _head_timer >= _tempo_proximo_olhar:

            _head_timer = 0.0

            _tempo_proximo_olhar = randf_range(2.5, 5.0)

            _target_head_rot = Quaternion.from_euler(Vector3(randf_range(-0.06, 0.06), randf_range(-0.18, 0.18), 0))

        _current_head_rot = _current_head_rot.slerp(_target_head_rot, delta * 2.5)

        _skeleton.set_bone_pose_rotation(_head_idx, _current_head_rot)


    # ----- 3. RESPIRAÇÃO -----

    _idle_time += delta * 1.5

    var spine_idx = _skeleton.find_bone("Spine")

    if spine_idx != -1:

        _skeleton.set_bone_pose_rotation(spine_idx, Quaternion.from_euler(Vector3(sin(_idle_time) * 0.02, 0, 0)))


    # ----- 4. EXPRESSÕES E WEBSOCKET -----

    for idx in _blend_targets:

        var speed = 25.0 if idx == _blink_idx else 12.0

        _blend_current[idx] = lerp(_blend_current[idx], _blend_targets[idx], delta * speed)

        _mesh.set_blend_shape_value(idx, _blend_current[idx])


    _socket.poll()

    if _socket.get_ready_state() == WebSocketPeer.STATE_OPEN:

        while _socket.get_available_packet_count():

            var msg = _socket.get_packet().get_string_from_utf8()

            if msg == "TALK:1": _set_blend(_mouth_idx, 0.8)

            elif msg == "TALK:0": _set_blend(_mouth_idx, 0.0)

            elif msg.begins_with("EXPRESSION:"):

                var expr = msg.split(":")[1].to_lower()

                for e in _expr_map.values(): _set_blend(e, 0.0)

                if _expr_map.has(expr) and _expr_map[expr] != -1:

                    _set_blend(_expr_map[expr], 1.0)


# ============================================

# FUNÇÕES DE APOIO

# ============================================

func _set_blend(idx, val):

    if idx != -1 and _blend_targets.has(idx):

        _blend_targets[idx] = val


func _piscar_loop():

    if _blink_idx != -1:

        _set_blend(_blink_idx, 1.0)

        await get_tree().create_timer(0.15).timeout

        _set_blend(_blink_idx, 0.0)

    await get_tree().create_timer(randf_range(3.0, 6.0)).timeout

    _piscar_loop()


func _detect_blend_shapes():

    if not _mesh or not _mesh.mesh: return

    for i in range(_mesh.mesh.get_blend_shape_count()):

        var name = _mesh.mesh.get_blend_shape_name(i).to_lower()

        if "mth_a" in name: _mouth_idx = i

        elif "close" in name or "blink" in name: _blink_idx = i

        elif "joy" in name: _expr_map["joy"] = i

        elif "angry" in name: _expr_map["angry"] = i

        elif "sorrow" in name or "sad" in name: _expr_map["sorrow"] = i

        elif "fun" in name: _expr_map["fun"] = i


func _find_mesh(node: Node) -> MeshInstance3D:

    if node is MeshInstance3D: return node

    for child in node.get_children():

        var found = _find_mesh(child)

        if found: return found

    return null






