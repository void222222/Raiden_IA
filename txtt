# ==========================================


def iniciar_caderno():


conexao = sqlite3.connect("memoria_raiden.db")


cursor = conexao.cursor()


# Tabela de histórico (Conversa)


cursor.execute('''


CREATE TABLE IF NOT EXISTS historico (


id INTEGER PRIMARY KEY AUTOINCREMENT,


autor TEXT,


mensagem TEXT


)


''')


# 📅 NOVA TABELA: Agenda de Compromissos


cursor.execute('''


CREATE TABLE IF NOT EXISTS agenda (


id INTEGER PRIMARY KEY AUTOINCREMENT,


tarefa TEXT,


data TEXT


)


''')


conexao.commit()


return conexao



def anotar_no_caderno(conexao, autor, mensagem):


cursor = conexao.cursor()


cursor.execute("INSERT INTO historico (autor, mensagem) VALUES (?, ?)", (autor, mensagem))


conexao.commit()



def ler_ultimas_conversas(conexao, limite=4):


cursor = conexao.cursor()


cursor.execute("SELECT autor, mensagem FROM historico ORDER BY id DESC LIMIT ?", (limite,))


linhas = cursor.fetchall()


linhas.reverse()


contexto = ""


for linha in linhas:


contexto += f"{linha[0]} diz: {linha[1]}\n"


return contexto



def salvar_tarefa(conexao, tarefa):


cursor = conexao.cursor()


data_atual = time.strftime("%d/%m/%Y") # Pega a data de hoje


cursor.execute("INSERT INTO agenda (tarefa, data) VALUES (?, ?)", (tarefa, data_atual))


conexao.commit()


return f"Tarefa '{tarefa}' anotada no caderno, preguiçoso."



def listar_tarefas(conexao):


cursor = conexao.cursor()


cursor.execute("SELECT tarefa FROM agenda")


tarefas = cursor.fetchall()


if not tarefas:


return "Sua agenda está vazia. Pelo menos nisso você não é um desastre."


lista = "Suas tarefas são: " + ", ".join([t[0] for t in tarefas])


return lista



