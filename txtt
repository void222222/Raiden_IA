captura = ouvir_microfone(silencioso=True)

if captura == "":

continue

if "encerrar sistema" in captura or "desligar sistema" in captura:

print("Raiden: Desligando. Tente não explodir nada enquanto eu estiver fora.")

falar("Desligando. Tente não explodir nada enquanto eu estiver fora.")

