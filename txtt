# ==========================================

# 🎵 MÁGICA DA TAG DINÂMICA (PESQUISA NO YOUTUBE)

# ==========================================

if "[TOCAR_MUSICA" in texto_resposta.upper():

try:

# Extrai o que a Raiden escreveu depois dos dois pontos. Ex: [TOCAR_MUSICA: slipknot]

pedido = re.search(r'\[TOCAR_MUSICA:(.*?)\]', texto_resposta, re.IGNORECASE).group(1).strip()

print(f"🎵 [DJ RAIDEN]: Entendi! Pesquisando '{pedido}' no YouTube...")

# Transforma os espaços em '+' (ex: "linkin park" vira "linkin+park")

pesquisa_formatada = pedido.replace(" ", "+")

link_musica = f"https://www.youtube.com/results?search_query={pesquisa_formatada}"

