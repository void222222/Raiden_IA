import requests

import json

import os

from gtts import gTTS

import pygame

import time


# Inicializa o sistema de som do Python

pygame.mixer.init()


# 🧠 MÓDULO 1: O CÉREBRO (Ollama)

def pensar(mensagem_usuario):

url = "http://localhost:11434/api/generate"

# O System Prompt que dá a personalidade pra ela

personalidade = """

Você é a Raiden. Uma assistente virtual Tsundere.

Você é meio mal-humorada, chama o usuário de 'idiota' ou 'preguiçoso', mas no fundo sempre responde a pergunta dele corretamente.

Seja bem curta e direta nas respostas, parecendo que está sem paciência. Responda em Português.

"""

payload = {

"model": "qwen2.5:7b", # Ou o modelo que você estiver usando (ex: llama3)

"prompt": f"{personalidade}\nUsuário diz: {mensagem_usuario}\nRaiden responde:",

"stream": False

}


print("🧠 Raiden está digitando...")

try:

response = requests.post(url, json=payload)

data = json.loads(response.text)

return data['response']

except Exception as e:

return f"Você quebrou alguma coisa, seu idiota! Erro: {e}"


# 👄 MÓDULO 2: A BOCA (Google TTS)

def falar(texto):

print("🗣️ Gerando voz...")

# Cria o áudio em português (pt)

tts = gTTS(text=texto, lang='pt', slow=False)

arquivo_audio = "fala_raiden.mp3"

tts.save(arquivo_audio)

# Toca o áudio salvo

pygame.mixer.music.load(arquivo_audio)

pygame.mixer.music.play()

# Espera o áudio terminar de tocar para continuar

while pygame.mixer.music.get_busy():

time.sleep(0.1)

# Apaga o arquivo de áudio pra não lotar o PC

os.remove(arquivo_audio)


# 🔄 MÓDULO 3: O CORPO (Loop de conversa)

print("--- INICIANDO A RAIDEN ---")

print("Escreva 'sair' para desligar.")


while True:

mensagem = input("\nVocê: ")

if mensagem.lower() == 'sair':

falar("Finalmente você me deixou em paz. Tchau, idiota!")

break

# 1. Manda o cérebro pensar

resposta_texto = pensar(mensagem)

print(f"\nRaiden: {resposta_texto}")

# 2. Manda a boca falar o que o cérebro pensou

falar(resposta_texto)


