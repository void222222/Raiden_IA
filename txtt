def ouvir_microfone(silencioso=False):

reconhecedor = sr.Recognizer()

# --- AJUSTES DE SENSIBILIDADE ---

# Quanto maior, mais alto você precisa falar para ela "ouvir"

reconhecedor.energy_threshold = 300

# Tempo de silêncio para ela entender que você terminou a frase

reconhecedor.pause_threshold = 1.2

# Evita que ela fique "surda" com barulho de teclado/cooler

reconhecedor.dynamic_energy_threshold = True

with sr.Microphone() as fonte:

if silencioso:

print("\n💤 Modo de espera... (Diga 'Raiden')")

else:

print("\n🎤 Ouvindo comando...")

# Diminuímos para 0.5 para ser mais rápido na live

reconhecedor.adjust_for_ambient_noise(fonte, duration=0.5)

try:

# timeout=5 para ela não ficar travada esperando

audio = reconhecedor.listen(fonte, timeout=5, phrase_time_limit=10)

if not silencioso:

print("⏳ Entendendo...")

texto = reconhecedor.recognize_google(audio, language="pt-BR").lower()

if texto.strip() == "":

return ""

return texto

except (sr.UnknownValueError, sr.WaitTimeoutError):

return ""

except Exception as e:

return ""


