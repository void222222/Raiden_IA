# Adicionei a variável 'silencioso' para ela não ficar floodando o terminal de texto


def ouvir_microfone(silencioso=False):


reconhecedor = sr.Recognizer()


# 🛑 AJUSTES DE "PACIÊNCIA" (Para não te cortar)


# Aumentamos para 2.5 segundos. Ela só para de ouvir se você ficar em silêncio ABSOLUTO por esse tempo.


reconhecedor.pause_threshold = 2.5


# Ela vai ignorar barulhos de fundo constantes (como o cooler do seu PC)


reconhecedor.dynamic_energy_threshold = True


reconhecedor.energy_threshold = 400 # Sensibilidade base (ajuste se precisar)



with sr.Microphone() as fonte:


if silencioso:


# No modo standby, ela precisa ser rápida para pegar o "Raiden"


print("\n💤 Raiden em standby...")


else:


print("\n🎤 Pode falar, não vou te cortar...")


# Ajuste de ruído super rápido (0.3s) para não perder o início da sua fala


reconhecedor.adjust_for_ambient_noise(fonte, duration=0.3)


try:


# phrase_time_limit=None permite que você fale por 1 hora se quiser


audio = reconhecedor.listen(fonte, timeout=None, phrase_time_limit=None)


if not silencioso:


print("⏳ Processando sua voz...")


texto = reconhecedor.recognize_google(audio, language="pt-BR").lower()


if texto.strip() == "":


return ""


return texto


except sr.UnknownValueError:


# Ela ouviu um som mas não entendeu palavra nenhuma


return ""


except Exception as e:


return ""# ==========================================


