import requests

import speech_recognition as sr

import os

import time

import re

import sqlite3 # 🛑 Importamos o banco de dados nativo do Python!


os.environ['PYGAME_HIDE_SUPPORT_PROMPT'] = "hide"

from gtts import gTTS

import pygame

from ctypes import *


# ==========================================

# 🛑 FEITIÇARIA PARA ESCONDER OS ERROS DO ALSA (LINUX)

# ==========================================

ERROR_HANDLER_FUNC = CFUNCTYPE(None, c_char_p, c_int, c_char_p, c_int, c_char_p)

def py_error_handler(filename, line, function, err, fmt):

pass

c_error_handler = ERROR_HANDLER_FUNC(py_error_handler)

try:

asound = cdll.LoadLibrary('libasound.so.2')

asound.snd_lib_error_set_handler(c_error_handler)

except OSError:

pass


# ==========================================

# 📓 MÓDULO: A MEMÓRIA (SQLite)

# ==========================================

def iniciar_caderno():

# Cria o arquivo memoria_raiden.db (ou se conecta se já existir)

conexao = sqlite3.connect("memoria_raiden.db")

cursor = conexao.cursor()

# Cria a tabela de histórico se ela não existir

cursor.execute('''

CREATE TABLE IF NOT EXISTS historico (

id INTEGER PRIMARY KEY AUTOINCREMENT,

autor TEXT,

mensagem TEXT

)

''')

conexao.commit()

return conexao


def anotar_no_caderno(conexao, autor, mensagem):

cursor = conexao.cursor()

# Salva quem falou e a mensagem no banco de dados

cursor.execute("INSERT INTO historico (autor, mensagem) VALUES (?, ?)", (autor, mensagem))

conexao.commit()


def ler_ultimas_conversas(conexao, limite=4):

cursor = conexao.cursor()

# Puxa as últimas mensagens (limite define quantas)

cursor.execute("SELECT autor, mensagem FROM historico ORDER BY id DESC LIMIT ?", (limite,))

linhas = cursor.fetchall()

# Inverte a ordem para ficar cronológico (a mais antiga primeiro, a mais nova por último)

linhas.reverse()

contexto = ""

for linha in linhas:

contexto += f"{linha[0]} diz: {linha[1]}\n"

return contexto


# ==========================================

# 👄 MÓDULO: A BOCA

# ==========================================

pygame.mixer.init()


def limpar_texto_para_voz(texto):

texto_limpo = texto.replace('"', '').replace('”', '').replace('“', '').replace("'", "")

texto_limpo = texto_limpo.replace('*', '')

texto_limpo = re.sub(r'\(.*?\)', '', texto_limpo)

return texto_limpo


def falar(texto):

texto_processado = limpar_texto_para_voz(texto)

print("🗣️ Raiden está falando...")

tts = gTTS(text=texto_processado, lang='pt', slow=False)

arquivo_audio = "voz.mp3"

tts.save(arquivo_audio)

pygame.mixer.music.load(arquivo_audio)

pygame.mixer.music.play()

while pygame.mixer.music.get_busy():

time.sleep(0.1)

os.remove(arquivo_audio)


# ==========================================

# 👂 MÓDULO: OS OUVIDOS

# ==========================================

def ouvir_microfone():

reconhecedor = sr.Recognizer()

reconhecedor.pause_threshold = 2.5

with sr.Microphone() as fonte:

print("\n🎤 Raiden está ouvindo... (Pode falar sem pressa!)")

reconhecedor.adjust_for_ambient_noise(fonte, duration=1)

try:

audio = reconhecedor.listen(fonte, timeout=10)

print("⏳ Entendendo o que você disse...")

texto = reconhecedor.recognize_google(audio, language="pt-BR")

if len(texto.split()) < 2:

return ""

print(f"Você: {texto}")

return texto

except (sr.UnknownValueError, sr.WaitTimeoutError):

return ""

except Exception as e:

print(f"❌ Erro: {e}")

return ""


# ==========================================

# 🧠 MÓDULO: O CÉREBRO

# ==========================================

url = "http://localhost:11434/api/generate"


personalidade = """Você é a Raiden. Uma assistente virtual muito inteligente, sarcástica e tsundere.

Gosta de chamar o usuário de idiota ou preguiçoso, mas no fundo ajuda ele.

REGRAS ABSOLUTAS:

1. RESPONDA EXCLUSIVAMENTE EM PORTUGUÊS DO BRASIL. NUNCA USE INGLÊS.

2. Responda de forma curta (máximo 2 ou 3 frases)."""


# Inicializamos a memória antes de começar a conversa

banco_de_dados = iniciar_caderno()


print("\n⚡ ACORDANDO A RAIDEN... (Fale 'encerrar' para sair)")

falar("Estou online. Pare de enrolar e me diga o que você quer.")


while True:

mensagem_usuario = ouvir_microfone()

if mensagem_usuario == "":

continue

if "encerrar" in mensagem_usuario.lower() or "sair" in mensagem_usuario.lower():

print("Raiden: Finalmente me deu paz. Já vai tarde!")

falar("Finalmente me deu paz. Já vai tarde!")

break


# 1. Salva a fala do usuário no caderno

anotar_no_caderno(banco_de_dados, "Usuário", mensagem_usuario)

# 2. Lê as últimas conversas para dar contexto

contexto_historico = ler_ultimas_conversas(banco_de_dados, limite=4)


# 3. Mandamos a personalidade + histórico + a mensagem nova

pacote = {

"model": "llama3",

"prompt": f"{personalidade}\n\nHistórico recente da conversa:\n{contexto_historico}\nRaiden responde:",

"stream": False,

"options": {

"temperature": 0.4

}

}


try:

print("🧠 Raiden está pensando e lembrando...")

resposta = requests.post(url, json=pacote)

dados = resposta.json()

if "error" in dados:

print(f"\n❌ Erro no Ollama: {dados['error']}")

else:

texto_resposta = dados['response']

print(f"Raiden: {texto_resposta}")

falar(texto_resposta)

# 4. Salva a resposta da Raiden no caderno também!

anotar_no_caderno(banco_de_dados, "Raiden", texto_resposta)

print("-" * 40)


except Exception as e:

print(f"Deu ruim na conexão! Erro: {e}")

break


📖 Documentação do Passo


import sqlite3: Traz as ferramentas de banco de dados para o nosso código.


iniciar_caderno(): Cria e conecta ao arquivo memoria_raiden.db. Usamos a linguagem SQL (CREATE TABLE IF NOT EXISTS) para garantir que a tabela seja criada apenas na primeira vez que você rodar o script.


anotar_no_caderno(...): Usa o comando INSERT INTO do SQL para colocar uma nova linha na tabela, guardando a string do autor (seja "Usuário" ou "Raiden") e a mensagem.


ler_ultimas_conversas(..., limite=4): Usa o comando SELECT do SQL. Nós puxamos apenas as últimas 4 mensagens (LIMIT 4) para não sobrecarregar o Llama 3. Se mandássemos 100 mensagens passadas de uma vez, ele ficaria confuso e lento. O modelo precisa apenas da memória recente para parecer inteligente e manter o fluxo.


