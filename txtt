def ouvir_microfone(silencioso=False, tempo_limite=30): # 30 segundos de limite na live

reconhecedor = sr.Recognizer()

reconhecedor.pause_threshold = 2.5

reconhecedor.dynamic_energy_threshold = True

reconhecedor.energy_threshold = 400


with sr.Microphone() as fonte:

if silencioso:

print(f"\n💤 Raiden em standby... (Se passar {tempo_limite}s no vácuo, ela vai reclamar)")

else:

print("\n🎤 Pode falar, não vou te cortar...")

reconhecedor.adjust_for_ambient_noise(fonte, duration=0.3)

try:

# 🛑 A MÁGICA DO RELÓGIO AQUI

timeout_aplicado = tempo_limite if silencioso else None

audio = reconhecedor.listen(fonte, timeout=timeout_aplicado, phrase_time_limit=None)

if not silencioso:

print("⏳ Processando sua voz...")

texto = reconhecedor.recognize_google(audio, language="pt-BR").lower()

if texto.strip() == "": return ""

return texto

except sr.WaitTimeoutError:

# Se deu timeout, significa que você deixou ela no vácuo

return "TIMEOUT_SILENCIO" if silencioso else ""

except sr.UnknownValueError:

return ""

except Exception as e:

return ""


