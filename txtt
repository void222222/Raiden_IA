# 📓 MÓDULO: A MEMÓRIA (SQLite)
# ==========================================
def iniciar_caderno():
    conexao = sqlite3.connect("memoria_raiden.db")
    cursor = conexao.cursor()
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS historico (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            autor TEXT,
            mensagem TEXT
        )
    ''')
    conexao.commit()
    return conexao

def anotar_no_caderno(conexao, autor, mensagem):
    cursor = conexao.cursor()
    cursor.execute("INSERT INTO historico (autor, mensagem) VALUES (?, ?)", (autor, mensagem))
    conexao.commit()

def ler_ultimas_conversas(conexao, limite=4):
    cursor = conexao.cursor()
    cursor.execute("SELECT autor, mensagem FROM historico ORDER BY id DESC LIMIT ?", (limite,))
    linhas = cursor.fetchall()
    linhas.reverse() 
    contexto = ""
    for linha in linhas:
        contexto += f"{linha[0]} diz: {linha[1]}\n"
    return contexto

# ==========================================
# 👄 MÓDULO: A BOCA
# ==========================================
pygame.mixer.init()

def limpar_texto_para_voz(texto):
    texto_limpo = texto.replace('"', '').replace('”', '').replace('“', '').replace("'", "")
    texto_limpo = texto_limpo.replace('*', '')
    texto_limpo = re.sub(r'\(.*?\)', '', texto_limpo)
    return texto_limpo

def falar(texto):
    texto_processado = limpar_texto_para_voz(texto)
    print("🗣️ Raiden está falando...")
    tts = gTTS(text=texto_processado, lang='pt', slow=False)
    arquivo_audio = "voz.mp3"
    tts.save(arquivo_audio)
    
    pygame.mixer.music.load(arquivo_audio)
    pygame.mixer.music.play()
    
    while pygame.mixer.music.get_busy():
        time.sleep(0.1)
        
    os.remove(arquivo_audio)

# ==========================================
# 👂 MÓDULO: OS OUVIDOS (Agora com Modo Standby)
# ==========================================
# Adicionei a variável 'silencioso' para ela não ficar floodando o terminal de texto
def ouvir_microfone(silencioso=False):
    reconhecedor = sr.Recognizer()
    reconhecedor.pause_threshold = 2.0 
    
    with sr.Microphone() as fonte:
        if silencioso:
            print("\n💤 Modo de espera... (Diga 'Raiden' para chamar)")
        else:
            print("\n🎤 Pode falar, estou ouvindo seu comando...")
            
        reconhecedor.adjust_for_ambient_noise(fonte, duration=1)
        try:
            audio = reconhecedor.listen(fonte, timeout=10)
            
            if not silencioso:
                print("⏳ Entendendo o que você disse...")
                
            texto = reconhecedor.recognize_google(audio, language="pt-BR").lower() # Deixa tudo minúsculo
            
            if texto.strip() == "":
                return ""
            
            return texto
            
        except (sr.UnknownValueError, sr.WaitTimeoutError):
            return ""
        except Exception as e:
            if not silencioso:
                print(f"❌ Erro: {e}")
            return ""

# ==========================================
# 🧠 MÓDULO: O CÉREBRO
# ==========================================
url = "http://localhost:11434/api/generate"

personalidade = """Você é a Raiden. Uma assistente virtual muito inteligente, sarcástica e tsundere. 
Gosta de chamar o usuário de idiota ou preguiçoso, mas no fundo ajuda ele. 
REGRAS ABSOLUTAS: 
1. RESPONDA EXCLUSIVAMENTE EM PORTUGUÊS DO BRASIL. NUNCA USE INGLÊS.
2. Responda de forma curta (máximo 2 ou 3 frases)."""

banco_de_dados = iniciar_caderno()

print("\n⚡ INICIANDO SISTEMA... (Diga 'encerrar sistema' para fechar)")
falar("Sistemas online. Me chame pelo meu nome se precisar de algo.")

while True:
    # 1. Escuta em modo silencioso (Standby)
    captura = ouvir_microfone(silencioso=True)
    
    if captura == "":
        continue
        
    if "encerrar sistema" in captura or "desligar sistema" in captura:
        print("Raiden: Desligando. Tente não explodir nada enquanto eu estiver fora.")
        falar("Desligando. Tente não explodir nada enquanto eu estiver fora.")
        break

    # 2. Verifica se a palavra de ativação foi dita
    if "raiden" in captura:
        print(f"\n[🔔 VOCÊ ACORDOU A RAIDEN]: {captura}")
        
        # Tira o "raiden" da frase para sobrar só o comando real
        comando = captura.replace("raiden", "").strip()
        
        # Se você disse APENAS "Raiden" e não perguntou nada junto
        if comando == "":
            falar("O que foi, idiota? Estou escutando.")
            # Abre o microfone de novo, mas agora no modo ativo para ouvir a pergunta
            comando = ouvir_microfone(silencioso=False)
            
            if comando == "":
                falar("Me chamou pra ficar calado? Voltei a dormir.")
                continue
                
        print(f"Comando final: {comando}")

        # 3. Agora sim, continua com o processo normal do banco de dados e Ollama
        anotar_no_caderno(banco_de_dados, "Usuário", comando)
        contexto_historico = ler_ultimas_conversas(banco_de_dados, limite=4)

        pacote = {
            "model": "llama3",
            "prompt": f"{personalidade}\n\nHistórico recente da conversa:\n{contexto_historico}\nRaiden responde:",
            "stream": False,
            "options": {
                "temperature": 0.4
            }
        }

        try:
            print("🧠 Raiden está pensando...")
            resposta = requests.post(url, json=pacote)
