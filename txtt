# ==========================================


pygame.mixer.init()



def limpar_texto_para_voz(texto):


texto_limpo = texto.replace('"', '').replace('”', '').replace('“', '').replace("'", "")


texto_limpo = texto_limpo.replace('*', '')


texto_limpo = re.sub(r'\(.*?\)', '', texto_limpo)


return texto_limpo



def falar(texto):


texto_processado = limpar_texto_para_voz(texto)


print("🗣️ Raiden está falando...")


tts = gTTS(text=texto_processado, lang='pt', slow=False)


arquivo_audio = "voz.mp3"


tts.save(arquivo_audio)


pygame.mixer.music.load(arquivo_audio)


pygame.mixer.music.play()


while pygame.mixer.music.get_busy():


time.sleep(0.1)


os.remove(arquivo_audio)



