import requests
import speech_recognition as sr
import os
import time
from gtts import gTTS
import pygame
from ctypes import *

# ==========================================
# 🛑 FEITIÇARIA PARA ESCONDER OS ERROS DO ALSA (LINUX)
# ==========================================
ERROR_HANDLER_FUNC = CFUNCTYPE(None, c_char_p, c_int, c_char_p, c_int, c_char_p)
def py_error_handler(filename, line, function, err, fmt):
    pass
c_error_handler = ERROR_HANDLER_FUNC(py_error_handler)
try:
    asound = cdll.LoadLibrary('libasound.so.2')
    asound.snd_lib_error_set_handler(c_error_handler)
except OSError:
    pass

# ==========================================
# 👄 MÓDULO: A BOCA (Voz)
# ==========================================
pygame.mixer.init()

def falar(texto):
    print("🗣️ Raiden está falando...")
    tts = gTTS(text=texto, lang='pt', slow=False)
    arquivo_audio = "voz.mp3"
    tts.save(arquivo_audio)
    
    pygame.mixer.music.load(arquivo_audio)
    pygame.mixer.music.play()
    
    while pygame.mixer.music.get_busy():
        time.sleep(0.1)
        
    os.remove(arquivo_audio)

# ==========================================
# 👂 MÓDULO: OS OUVIDOS (Microfone)
# ==========================================
def ouvir_microfone():
    reconhecedor = sr.Recognizer()
    with sr.Microphone() as fonte:
        print("\n🎤 Raiden está ouvindo... (Pode falar!)")
        reconhecedor.adjust_for_ambient_noise(fonte, duration=1)
        try:
            audio = reconhecedor.listen(fonte, timeout=5, phrase_time_limit=15)
            print("⏳ Entendendo o que você disse...")
            texto = reconhecedor.recognize_google(audio, language="pt-BR")
            print(f"Você: {texto}")
            return texto
        except sr.UnknownValueError:
            return ""
        except sr.WaitTimeoutError:
            return ""
        except Exception as e:
            print(f"❌ Erro: {e}")
            return ""

# ==========================================
# 🧠 MÓDULO: O CÉREBRO (Ollama)
# ==========================================
url = "http://localhost:11434/api/generate"
personalidade = "Você é a Raiden. Uma assistente virtual muito inteligente, sarcástica e tsundere. Gosta de chamar o usuário de idiota ou preguiçoso, mas no fundo ajuda ele. Responda de forma curta (máximo 2 frases) para a voz não ficar muito longa."

print("\n⚡ ACORDANDO A RAIDEN... (Fale 'encerrar' para sair)")
falar("Estou online. O que você quer, idiota?")

while True:
    mensagem_usuario = ouvir_microfone()
    
    if mensagem_usuario == "":
        continue
        
    if "encerrar" in mensagem_usuario.lower() or "sair" in mensagem_usuario.lower():
        print("Raiden: Finalmente me deu paz. Já vai tarde!")
        falar("Finalmente me deu paz. Já vai tarde!")
        break

    pacote = {
        "model": "llama3",  # Seu modelo do Ollama
        "prompt": f"{personalidade}\nUsuário diz: {mensagem_usuario}\nRaiden responde:",
        "stream": False
    }

    try:
        print("🧠 Raiden está pensando...")
        resposta = requests.post(url, json=pacote)
        dados = resposta.json()
        
        if "error" in dados:
            print(f"\n❌ Erro no Ollama: {dados['error']}")
        else:
            texto_resposta = dados['response']
            print(f"Raiden: {texto_resposta}")
            falar(texto_resposta)
            print("-" * 40)

    except Exception as e:
        print(f"Deu ruim na conexão! Erro: {e}")
        break

