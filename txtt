def ouvir_microfone(silencioso=False):

reconhecedor = sr.Recognizer()

reconhecedor.pause_threshold = 2.5

reconhecedor.dynamic_energy_threshold = True

reconhecedor.energy_threshold = 400


with sr.Microphone() as fonte:

if silencioso:

print("\n💤 Raiden em standby... (Monitorando o vácuo)")

else:

print("\n🎤 Pode falar, não vou te cortar...")

reconhecedor.adjust_for_ambient_noise(fonte, duration=0.3)

try:

# Ouve rapidinho (5s) e solta pro Python checar o relógio absoluto

timeout_aplicado = 5 if silencioso else None

audio = reconhecedor.listen(fonte, timeout=timeout_aplicado, phrase_time_limit=None)

if not silencioso:

print("⏳ Processando sua voz...")

texto = reconhecedor.recognize_google(audio, language="pt-BR").lower()

return texto if texto.strip() != "" else ""

except (sr.WaitTimeoutError, sr.UnknownValueError, Exception):

return ""


