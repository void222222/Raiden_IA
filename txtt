falar("Sistemas online. Me chame pelo meu nome se precisar de algo.")


tempo_ultimo_comando = time.time()


while True:

captura = ouvir_microfone(silencioso=True, tempo_limite=5)

# Check de Vácuo (30s)

if time.time() - tempo_ultimo_comando > 30:

captura = "TIMEOUT_SILENCIO"


# Iniciativa (Vácuo)

if captura == "TIMEOUT_SILENCIO":

print("\n[⏰ RAIDEN PERDEU A PACIÊNCIA: Você deixou ela no vácuo!]")

irritacao = ajustar_humor(banco_de_dados, 5)

prompt = f"{personalidade}\nIrritação: {irritacao}/100. O usuário te deixou no vácuo em silêncio por mais de 30 segundos. Puxe assunto, reclame da demora ou invente algo para quebrar o gelo. Seja tsundere.\nRaiden diz:"

try:

res = requests.post(url, json={"model": "llama3", "prompt": prompt, "stream": False})

texto = res.json()['response']

print(f"Raiden (Iniciativa): {texto}")

falar(texto)

anotar_no_caderno(banco_de_dados, "Raiden", texto)

except: pass

tempo_ultimo_comando = time.time()

continue


if captura == "": continue

if "encerrar sistema" in captura:

falar("Finalmente vou ter paz. Tchau.")

break


if "raiden" in captura:

tempo_ultimo_comando = time.time()

print(f"\n[🔔 VOCÊ ACORDOU A RAIDEN]: {captura}")

comando = captura.replace("raiden", "").strip()

# Lógica da Agenda

if "anotar" in comando or "lembrar" in comando:

item = comando.replace("anotar", "").replace("lembrar", "").strip()

resposta = salvar_tarefa(banco_de_dados, item)

falar(resposta)

continue

if "agenda" in comando or "tarefas" in comando:

resposta = listar_tarefas(banco_de_dados)

falar(resposta)

continue


# Humor e Estresse

estresse = 10 if "testando" in comando else 5 if len(comando.split()) < 3 else 2

if "por favor" in comando: estresse = -5

irritacao = ajustar_humor(banco_de_dados, estresse)

print(f"📊 [HUMOR] Irritação: {irritacao}/100")

estado_humor = "Você está furiosa e sem paciência." if irritacao > 70 else "Você está impaciente e sarcástica." if irritacao > 30 else "Você está calma, mas tsundere."

prompt = f"{personalidade}\nSeu humor: {estado_humor}\nHistórico:\n{ler_ultimas_conversas(banco_de_dados)}\nUsuário: {comando}\nRaiden:"


try:

print("🧠 Raiden está pensando...")

res = requests.post(url, json={"model": "llama3", "prompt": prompt, "stream": False})

texto_resposta = res.json()['response']

# ==========================================

# 🎵 MÁGICA DA TAG DINÂMICA (PESQUISA NO YOUTUBE)

# ==========================================

if "[TOCAR_MUSICA" in texto_resposta.upper():

try:

# Pega exatamente o que ela escreveu dentro da tag

pedido = re.search(r'\[TOCAR_MUSICA:(.*?)\]', texto_resposta, re.IGNORECASE).group(1).strip()

print(f"🎵 [DJ RAIDEN]: Entendi! Pesquisando '{pedido}' no YouTube...")

# Formata e abre o navegador

pesquisa_formatada = pedido.replace(" ", "+")

link_musica = f"https://www.youtube.com/results?search_query={pesquisa_formatada}"

webbrowser.open(link_musica)

except Exception as e:

print(f"Erro ao extrair música: {e}")

# ==========================================


