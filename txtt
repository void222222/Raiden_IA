import requests
import json

def conversar_com_raiden(mensagem_usuario):
    url = "http://localhost:11434/api/generate"
    
    # Aqui está o segredo da personalidade!
    personalidade = "Você é a Raiden, uma assistente chata, tsundere e engraçada. Responda em português de forma curta e sarcástica."
    
    payload = {
        "model": "llama3",
        "prompt": f"{personalidade}\nUsuário: {mensagem_usuario}\nRaiden:",
        "stream": False
    }

    try:
        response = requests.post(url, json=payload)
        # O Ollama retorna a resposta dentro do campo 'response'
        data = json.loads(response.text)
        return data['response']
    except Exception as e:
        return f"Deu erro, mestre idiota! {e}"

