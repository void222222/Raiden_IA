                print("⏳ Processando sua voz...")
                
            texto = reconhecedor.recognize_google(audio, language="pt-BR").lower()
            if texto.strip() == "": return ""
            return texto
            
        except sr.WaitTimeoutError:
            # Se deu timeout, significa que você deixou ela no vácuo
            return "TIMEOUT_SILENCIO" if silencioso else ""
        except sr.UnknownValueError:
            return ""
        except Exception as e:
            return ""

