def limpar_texto_para_voz(texto):
    texto_limpo = texto.replace('"', '').replace('”', '').replace('“', '').replace("'", "")
    texto_limpo = texto_limpo.replace('*', '')
    texto_limpo = re.sub(r'\(.*?\)', '', texto_limpo)
    return texto_limpo

def falar(texto):
    texto_processado = limpar_texto_para_voz(texto)
    print("🗣️ Raiden está falando...")
