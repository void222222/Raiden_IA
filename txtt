comando = captura.replace("raiden", "").strip()

# --- Lógica da Agenda ---

if "anotar" in comando or "lembrar" in comando:

# Tira as palavras de comando para sobrar só a tarefa

item = comando.replace("anotar", "").replace("lembrar", "").strip()

